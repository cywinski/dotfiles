  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r .cwd); branch=$(git -C \"$cwd\" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?'); echo \"$input\" | jq -r --arg b \"$branch\" '\"[\\(.model.display_name)] \\(.context_window.used_percentage // 0)% context | \\($b)\"'"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "remoteControlAtStartup": true
